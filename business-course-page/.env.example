# Локально: прокси /api → server (см. vite.config.js). VITE_API_BASE не нужен.
#
# GitHub Pages: статика не принимает POST — запросы к /api на github.io дают 405.
# Собери с URL API на Render:
#   set VITE_API_BASE=https://triz-vip-api.onrender.com&& npm run build
# (PowerShell: $env:VITE_API_BASE="https://..."; npm run build)
#
# База пути:
#   GitHub Pages (репозиторий TRIZ-VIP): по умолчанию /TRIZ-VIP/ — можно не задавать.
#   Render static (корень сайта): VITE_BASE=/

# VITE_BASE=/TRIZ-VIP/
# VITE_API_BASE=https://triz-vip-api.onrender.com
